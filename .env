VOICE_AGENT_INPUT_DEVICE=default
VOICE_AGENT_OUTPUT_DEVICE=default
VOICE_AGENT_SAMPLE_RATE=16000
VOICE_AGENT_CHANNELS=1
VOICE_AGENT_SAMPLE_FORMAT=S16_LE
VOICE_AGENT_RECORD_SECONDS=5
VOICE_AGENT_RECORDINGS_DIR=data/recordings


OPENAI_API_KEY=xxxxxxxxxxxxxx
VOICE_AGENT_STT_MODEL=gpt-4o-mini-transcribe
VOICE_AGENT_STT_LANGUAGE=es
VOICE_AGENT_STT_PROMPT=

VOICE_AGENT_TTS_MODEL=gpt-4o-mini-tts
VOICE_AGENT_TTS_VOICE=verse
VOICE_AGENT_TTS_FORMAT=wav
VOICE_AGENT_TTS_INSTRUCTIONS="voz masculina latino neutro, tono natural conversacional"
VOICE_AGENT_TTS_OUTPUT_DIR=data/generated_audio


VOICE_AGENT_LLM_MODEL=gpt-4o-mini
VOICE_AGENT_SYSTEM_PROMPT="Eres un asistente de voz breve, claro y útil. Responde en español de forma natural."
VOICE_AGENT_MAX_OUTPUT_TOKENS=200